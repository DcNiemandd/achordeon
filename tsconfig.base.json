{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@achordeon/api/products": ["./libs/api/products/src/index.ts"],
      "@achordeon/models": ["./libs/shared/models/src/index.ts"],
      "@achordeon/shop/data": ["./libs/shop/data/src/index.ts"],
      "@achordeon/shop/feature-product-detail": [
        "./libs/shop/feature-product-detail/src/index.ts"
      ],
      "@achordeon/shop/feature-products": [
        "./libs/shop/feature-products/src/index.ts"
      ],
      "@achordeon/shop/shared-ui": ["./libs/shop/shared-ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
