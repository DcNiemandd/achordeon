# Achordeon local env — copy to `.env.local` and adjust if needed.
#
#   cp .env.local.example .env.local
#
# `.env.local` is gitignored; this example is committed. The same two variables
# drive local and deployed builds (CI sets them as repo variables), so there is
# one flow everywhere. `apps/app/tools/gen-supabase.mjs` reads them (real
# process.env wins over this file) and writes src/app/supabase.config.ts before
# build/serve/test.
#
# The anon key is PUBLIC by design — the browser holds it, RLS is the guard
# (ADR-0003) — so it is safe in an env file. Never put the service_role/secret key here.
#
# The defaults below are the local `supabase start` stack. If your CLI prints a
# different anon key (`supabase status`), paste it here — Kong rejects any other
# key with 403.
#
# Set SUPABASE_URL= (empty) to build with NO backend (offline-only): the
# Audience UI reports itself unavailable instead of erroring.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
