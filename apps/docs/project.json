{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/docs",
  "tags": [],
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @achordeon/docs run start"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/build"],
      "options": {
        "command": "pnpm --filter @achordeon/docs run build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "pnpm --filter @achordeon/docs run serve"
      }
    },
    "clear": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @achordeon/docs run clear"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @achordeon/docs run typecheck"
      }
    }
  }
}
