<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>app</title>
    <base href="/" />
    <!-- interactive-widget=resizes-content: when the on-screen keyboard opens,
         shrink the layout above it instead of letting it overlay content. That
         is what keeps the editor and the Source/Render switcher usable with the
         keyboard up, rather than hidden behind it. Chrome/Android honours it;
         other engines fall back to their default and lose nothing. -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, interactive-widget=resizes-content"
    />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <script>
      // Pre-paint theme stamp (PRD-UI-SHELL.md §6). Angular boots after first
      // paint, so without this a dark-mode user gets a white flash. Mirrors
      // ThemeApplier: 'system' means NO attribute, so the token sheet's bare
      // :root can follow prefers-color-scheme.
      (function () {
        try {
          var theme = localStorage.getItem('achordeon.theme');
          if (theme === 'dark' || theme === 'light') {
            document.documentElement.setAttribute('data-theme', theme);
          }
        } catch (e) {}
      })();
    </script>
    <script>
      // SPA deep-link restore (PRD-INFRASTRUCTURE deploy note). GitHub Pages has
      // no per-app 404, so the site's root 404 page redirects an app deep link
      // like `/achordeon/app/songs` into `/achordeon/app/?/songs`; this turns
      // that back into the real path before the router — and the locale redirect
      // below — reads the URL. A normal load has no leading "/" in its query, so
      // this is a no-op then. (github.com/rafgraph/spa-github-pages)
      (function () {
        var l = window.location;
        if (l.search[1] === '/') {
          var decoded = l.search
            .slice(1)
            .split('&')
            .map(function (s) {
              return s.replace(/~and~/g, '&');
            })
            .join('?');
          window.history.replaceState(
            null,
            '',
            l.pathname.slice(0, -1) + decoded + l.hash,
          );
        }
      })();
    </script>
    <script>
      (function () {
        try {
          var FLAG = 'achordeon-app-locale-init';
          if (localStorage.getItem(FLAG)) return;
          localStorage.setItem(FLAG, '1');
          var SUPPORTED = __ACHORDEON_LOCALES__;
          var DEFAULT = __ACHORDEON_DEFAULT_LOCALE__;
          var BASE = __ACHORDEON_BASE_HREF__;
          var path = location.pathname;
          if (path.indexOf(BASE) !== 0) return;
          var seg = path.slice(BASE.length).split('/')[0];
          var current = SUPPORTED.indexOf(seg) >= 0 ? seg : DEFAULT;
          var nav = (navigator.language || DEFAULT).slice(0, 2).toLowerCase();
          var target = SUPPORTED.indexOf(nav) >= 0 ? nav : DEFAULT;
          if (target === current) return;
          var tail = path.slice(BASE.length + (current === DEFAULT ? 0 : current.length + 1));
          var dest = BASE + (target === DEFAULT ? '' : target + '/') + tail + location.search + location.hash;
          location.replace(dest);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <app-root></app-root>
  </body>
</html>
