{
  "name": "app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/app/src",
  "tags": ["type:app"],
  "i18n": {
    "sourceLocale": { "code": "en", "subPath": "" },
    "locales": {
      "cs": {
        "translation": "apps/app/src/locale/messages.cs.xlf",
        "subPath": "cs"
      }
    }
  },
  "targets": {
    "gen-index": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/index.html.template",
        "{projectRoot}/project.json",
        "{projectRoot}/tools/gen-index.mjs"
      ],
      "outputs": ["{projectRoot}/src/index.html"],
      "options": {
        "command": "node tools/gen-index.mjs",
        "cwd": "apps/app"
      }
    },
    "gen-supabase": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": ["{projectRoot}/src/app/supabase.config.ts"],
      "options": {
        "command": "node tools/gen-supabase.mjs",
        "cwd": "apps/app"
      }
    },
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["gen-index", "gen-supabase"],
      "options": {
        "outputPath": "dist/apps/app",
        "browser": "apps/app/src/main.ts",
        "polyfills": ["@angular/localize/init"],
        "tsConfig": "apps/app/tsconfig.app.json",
        "baseHref": "/achordeon/app/",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/app/public"
          }
        ],
        "styles": [
          "@fontsource-variable/roboto-mono/index.css",
          "apps/app/src/styles.scss"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "600kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "localize": true
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "localize": ["en"]
        },
        "cs": {
          "localize": ["cs"]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "dependsOn": ["gen-index", "gen-supabase"],
      "configurations": {
        "production": {
          "buildTarget": "app:build:production"
        },
        "development": {
          "buildTarget": "app:build:development"
        },
        "cs": {
          "buildTarget": "app:build:development,cs"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "dependsOn": ["gen-index"],
      "options": {
        "buildTarget": "app:build",
        "outputPath": "apps/app/src/locale",
        "format": "xlf"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "dependsOn": ["gen-supabase"],
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/app/jest.config.ts",
        "tsConfig": "apps/app/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "app:build",
        "port": 4200,
        "staticFilePath": "dist/apps/app/browser",
        "spa": true
      }
    }
  }
}
